DB_NAME=nba_db
DB_USER=nba_user
DB_PASSWORD=nba_password
DB_HOST=localhost
DB_PORT=5432

# Optional: Railway and other platforms often provide DATABASE_URL instead
# DATABASE_URL=postgresql://nba_user:nba_password@localhost:5432/nba_db

# Production promotion intentionally has no example value here. Export
# PRODUCTION_DATABASE_URL interactively for `make season-promote`; scheduled
# backups use the encrypted GitHub Actions secret with the same name. Never
# commit it or put its value in command arguments or logs.

# Staging follows the same secret boundary. Export STAGING_DATABASE_URL only
# while loading an isolated staging environment; do not commit its value.

# Backup drills require a separate, nonexistent database whose name ends in
# `_recovery`. Export RECOVERY_DATABASE_URL only while running `make restore-drill`.

# Optional: when set, scripts/init_db.py creates a SELECT-only role `nba_readonly`
# with this password, and the web app connects as that role instead of the owner.
# READONLY_DB_PASSWORD=change-me

# Public API protection. Defaults are shown; adjust only from observed traffic.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=600
# RATE_LIMIT_EXPENSIVE_REQUESTS=120
# RATE_LIMIT_WINDOW_SECONDS=60

# Verified artifact uploads use short-lived operator shell variables returned by
# `railway bucket credentials`; never commit object-storage credentials here.
